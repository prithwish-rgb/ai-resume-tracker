# ─── Database ───────────────────────────────────────────────
MONGODB_URI="mongodb+srv://user:pass@cluster.mongodb.net/airesume?retryWrites=true&w=majority"

# ─── NextAuth ───────────────────────────────────────────────
NEXTAUTH_SECRET="run: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ─── OAuth Providers (optional) ─────────────────────────────
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# ─── AI (REQUIRED for resume tailoring, job parsing, interview prep, negotiation) ───
# Get a free key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
# Optional override; defaults to gemini-2.5-flash (free tier friendly)
GEMINI_MODEL="gemini-2.5-flash"

# ─── Runtime ────────────────────────────────────────────────
NODE_ENV="development"
